{
  "name": "devpilot-mcp",
  "version": "1.0.0",
  "description": "Unified DevOps lifecycle MCP server — GitHub Actions, Vercel, Railway, Sentry, health monitoring",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "devpilot-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^9.4.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.12.0",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "devops",
    "vercel",
    "railway",
    "sentry",
    "github-actions",
    "claude"
  ],
  "license": "MIT"
}
